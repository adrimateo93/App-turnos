# ============================================================
# SeguriTurno — Backend Environment Variables (PRODUCCIÓN)
# ============================================================
# COPIA ESTE ARCHIVO A .env Y RELLENA LOS VALORES REALES
# NUNCA subas .env a Git (ya está en .gitignore)
# ============================================================

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=seguriturno_db

# JWT — genera un secreto fuerte: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_SEGURO_DE_64_CARACTERES

# Server
PORT=8001
HOST=0.0.0.0
ENVIRONMENT=production

# CORS — dominio(s) de tu frontend separados por coma
# Ejemplo: https://app.seguriturno.com,https://www.seguriturno.com
ALLOWED_ORIGINS=http://localhost:3000

# URL pública del frontend (para enlaces en emails)
APP_URL=http://localhost:3000

# Email / SMTP (para recuperación de contraseña)
# Usa Gmail, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_contraseña_de_aplicacion
