# ============================================================
# SeguriTurno Backend — Variables de entorno
# Configura estas mismas variables en Render:
#   Dashboard → Tu servicio → Environment
# ============================================================

# MongoDB Atlas — reemplaza con tu connection string
# Formato: mongodb+srv://usuario:password@cluster.mongodb.net/seguriturno_db
MONGO_URL=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/seguriturno_db?retryWrites=true&w=majority
DB_NAME=seguriturno_db

# JWT — clave secreta fuerte (mínimo 32 caracteres)
# Genera una en: https://generate-secret.vercel.app/32
JWT_SECRET=CAMBIA_ESTO_genera_un_secreto_de_minimo_32_caracteres

# Servidor
PORT=8001
HOST=0.0.0.0
ENVIRONMENT=production

# CORS — URL de tu frontend en Vercel (sin barra final)
# Ejemplo: https://seguriturno.vercel.app
ALLOWED_ORIGINS=https://seguriturno.vercel.app

# URL pública del frontend (para enlaces en emails)
APP_URL=https://seguriturno.vercel.app

# Email SMTP (para recuperación de contraseña)
# Con Gmail: activa "contraseñas de aplicación" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
